# ==========================================
# LOCAL SERVICES
# ==========================================
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:pass@localhost:5432/av_db

# ==========================================
# LIVEKIT — WebRTC Infrastructure
# Crear cuenta en: https://livekit.io
# Dashboard → tu proyecto → Settings → Keys
#
# Dónde van cada variable:
#   LIVEKIT_API_KEY    → Vercel (admin-dashboard) + live-engine/.env.local
#   LIVEKIT_API_SECRET → Vercel (admin-dashboard) + live-engine/.env.local
#   VITE_LIVEKIT_URL   → Vercel (admin-dashboard) + apps/admin-dashboard/.env.local
# ==========================================
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# ==========================================
# MUX — Video encoding & storage (opcional)
# ==========================================
MUX_TOKEN_ID=your_mux_token_id_here
MUX_TOKEN_SECRET=your_mux_token_secret_here
