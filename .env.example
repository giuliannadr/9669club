# ==========================================
# LOCAL SERVICES
# ==========================================
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:pass@localhost:5432/av_db

# ==========================================
# LIVEKIT — WebRTC Infrastructure
# Crear cuenta en: https://livekit.io
# Ir a: Settings > Keys para obtener las credenciales
# ==========================================

# Server-side (web-portfolio API route) — NUNCA exponer al cliente
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Client-side (admin-dashboard) — URL pública del servidor LiveKit
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# URL del web-portfolio donde vive la API de tokens
# En local: http://localhost:3000
# En producción: https://tu-dominio.vercel.app
VITE_TOKEN_API_URL=http://localhost:3000

# ==========================================
# MUX — Video encoding & storage (opcional)
# ==========================================
MUX_TOKEN_ID=your_mux_token_id_here
MUX_TOKEN_SECRET=your_mux_token_secret_here
